{
  "name": "@conform-ed/coverage",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./maps/open-badges/v3_0": "./maps/open-badges-v3.0.json"
  },
  "scripts": {
    "build": "tsgo --noEmit",
    "coverage:check": "bun run scripts/generate.ts --check",
    "coverage:generate": "bun run scripts/generate.ts",
    "format": "oxfmt --config ../../.oxfmtrc.jsonc --check src test specs scripts",
    "lint": "oxlint --config ../../.oxlintrc.jsonc src test specs scripts",
    "test": "bun test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@conform-ed/contracts": "workspace:*",
    "fast-xml-parser": "^5.9.3",
    "n3": "^2.1.0"
  },
  "devDependencies": {
    "@types/n3": "^1.26.1"
  },
  "peerDependencies": {
    "zod": ">=4.4.0"
  }
}
