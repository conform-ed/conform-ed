    {
      "key": "lti:1.3:param:limit",
      "kind": "parameter",
      "path": "limit",
      "description": "restricts the maximum number of items to be returned. The response may be further constrained."
    },
    {
      "key": "lti:1.3:param:page",
      "kind": "parameter",
      "path": "page",
      "description": "indicates the offset for which this page should start containing items. Used exclusively by the nextPage URL. For illustration purposes only. It is up to the tool platform to decide how to encode the offset in the next page URL."
    },
    {
      "key": "lti:1.3:param:resource_id",
      "kind": "parameter",
      "path": "resource_id",
      "description": "limit the line items returned to only those which have been associated with the specified tool resource ID"
    },
    {
      "key": "lti:1.3:param:resource_link_id",
      "kind": "parameter",
      "path": "resource_link_id",
      "description": "limit the line items returned to only those which have been associated with the specified tool platform's resource link"
    },
    {
      "key": "lti:1.3:param:tag",
      "kind": "parameter",
      "path": "tag",
      "description": "limit the line items returned to only those which have been associated with the specified tag"
    },
    {
      "key": "lti:1.3:param:user_id",
      "kind": "parameter",
      "path": "user_id",
      "description": "limit the line items returned to only those which have been associated with this user. Results must contain at most one result."
    },
    {
      "key": "lti:1.3:path:ags/DELETE /{contextId}/lineitems/{lineItemId}",
      "kind": "operation",
      "path": "DELETE /{contextId}/lineitems/{lineItemId}",
      "description": "removes the line item. While no more associated with the tool, the tool platform may decide to keep the line item around (unassociated)"
    },
    {
      "key": "lti:1.3:path:ags/GET /{contextId}/lineitems",
      "kind": "operation",
      "path": "GET /{contextId}/lineitems",
      "description": "returns all the line items associated to tool in the specified learning context. Results may be broken in multiple pages in particular if a limit parameter is present."
    },
    {
      "key": "lti:1.3:path:ags/GET /{contextId}/lineitems/{lineItemId}",
      "kind": "operation",
      "path": "GET /{contextId}/lineitems/{lineItemId}",
      "description": "returns the current value for the line item."
    },
    {
      "key": "lti:1.3:path:ags/GET /{contextId}/lineitems/{lineItemId}/results",
      "kind": "operation",
      "path": "GET /{contextId}/lineitems/{lineItemId}/results",
      "description": "returns all the results for the line item (results for all the students in the current context for this line item) Results may be broken in multiple pages in particular if a limit parameter is present."
    },
    {
      "key": "lti:1.3:path:ags/POST /{contextId}/lineitems",
      "kind": "operation",
      "path": "POST /{contextId}/lineitems",
      "description": "add a new line item; the created line item is returned with an id property being the url to be used to later update, delete the item, post new scores (by appending /scores to the path), or getting the current results associated with that lineitem (by appending /results to the path)."
    },
    {
      "key": "lti:1.3:path:ags/POST /{contextId}/lineitems/{lineItemId}/scores",
      "kind": "operation",
      "path": "POST /{contextId}/lineitems/{lineItemId}/scores",
      "description": "publishes a score update. Tool platform may decide to change the result value based on the updated score."
    },
    {
      "key": "lti:1.3:path:ags/PUT /{contextId}/lineitems/{lineItemId}",
      "kind": "operation",
      "path": "PUT /{contextId}/lineitems/{lineItemId}",
      "description": "updates the line item"
    }
