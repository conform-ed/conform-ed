      "key": "lti:1.3:def:Score/scoreMaximum",
      "kind": "property",
      "path": "scoreMaximum",
      "jsonType": "number",
      "description": "Maximum possible score for this result; It must be present if scoreGiven is present.",
      "modelled": "yes"
