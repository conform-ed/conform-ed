      "profile": "statement",
      "reqId": "XAPI-STMT-6",
      "level": "MUST",
      "statement": "An Activity Definition's interactionType MUST be one of the ten CMI interaction types (true-false, choice, fill-in, long-fill-in, matching, performance, sequencing, likert, numeric, other), and the interaction sub-components MUST NOT appear without it.",
      "constrains": [
        "xapi:2.0:def:ActivityDefinition/interactionType"
      ],
      "source": "IEEE Std 9274.1.1-2023 (xAPI Base Standard, Part Two: Data) — https://opensource.ieee.org/xapi"
