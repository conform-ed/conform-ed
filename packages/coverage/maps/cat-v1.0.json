      "key": "cat:1.0:conf:delivery/CAT-DEL-3",
      "profile": "delivery",
      "reqId": "CAT-DEL-3",
      "level": "MUST",
      "statement": "A CatEngineResultReport MUST carry a reportId, the section, and a recommendation (continue/finish/suspend/abandon); it MAY carry the ability estimate, section score, delivered outcomes and the next item stage.",
