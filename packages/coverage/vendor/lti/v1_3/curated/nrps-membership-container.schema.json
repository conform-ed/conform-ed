{
  "$id": "conform-ed:curated:lti/1.3/nrps/membership-container",
  "$comment": "Hand-authored denominator (conform-ed ADR-0017) — LTI NRPS 2.0 publishes no machine-readable schema for the membership container, only prose + inline JSON examples. Source: LTI NRPS 2.0 §2.1 (membership container) / §4.2 (membership) — https://www.imsglobal.org/spec/lti-nrps/v2p0. Lowest provenance tier; re-review on spec version bump.",
  "title": "LTI NRPS 2.0 membership container",
  "type": "object",
  "required": ["id", "context", "members"],
  "properties": {
    "id": { "type": "string", "$comment": "specRef: §2.1 (container id — the membership URL)" },
    "context": { "$ref": "#/$defs/NrpsContext", "$comment": "specRef: §2.1 (context)" },
    "members": {
      "type": "array",
      "items": { "$ref": "#/$defs/NrpsMember" },
      "$comment": "specRef: §2.1 (members array)"
    }
  },
  "$defs": {
    "NrpsContext": {
      "type": "object",
      "title": "membership context",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "$comment": "specRef: §2.1 (context.id)" },
        "label": { "type": "string", "$comment": "specRef: §2.1 (context.label)" },
        "title": { "type": "string", "$comment": "specRef: §2.1 (context.title)" }
      }
    },
    "NrpsMember": {
      "type": "object",
      "title": "membership member",
      "required": ["userId", "roles"],
      "properties": {
        "userId": { "type": "string", "$comment": "specRef: §4.2 (user_id — the launch sub)" },
        "roles": {
          "type": "array",
          "items": { "type": "string" },
          "$comment": "specRef: §4.2 (roles array of role URIs)"
        },
        "status": {
          "type": "string",
          "enum": ["Active", "Inactive", "Deleted"],
          "$comment": "specRef: §4.2 (member status — Inactive/Deleted must be honoured)"
        },
        "name": { "type": "string", "$comment": "specRef: §4.2 (name)" },
        "picture": { "type": "string", "$comment": "specRef: §4.2 (picture URL)" },
        "givenName": { "type": "string", "$comment": "specRef: §4.2 (given_name)" },
        "familyName": { "type": "string", "$comment": "specRef: §4.2 (family_name)" },
        "middleName": { "type": "string", "$comment": "specRef: §4.2 (middle_name)" },
        "email": { "type": "string", "$comment": "specRef: §4.2 (email)" },
        "lisPersonSourcedId": { "type": "string", "$comment": "specRef: §4.2 (lis_person_sourcedid)" },
        "roleScopeMentor": {
          "type": "array",
          "items": { "type": "string" },
          "$comment": "specRef: §4.2 (role_scope_mentor)"
        }
      }
    }
  }
}
