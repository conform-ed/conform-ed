{
  "$id": "conform-ed:curated:lti/1.3/proctoring/end-assessment-message",
  "$comment": "Hand-authored denominator (conform-ed ADR-0017) — LTI Proctoring Services 1.0 publishes no machine-readable schema, only prose + inline JSON examples. Source: LTI Proctoring Services 1.0 §5 (end assessment) — https://www.imsglobal.org/spec/proctoring/v1p0. Lowest provenance tier; re-review on spec version bump.",
  "title": "LTI Proctoring 1.0 EndAssessment message (normalized)",
  "type": "object",
  "required": ["messageType", "version", "deploymentId", "targetLinkUri", "subject", "attemptNumber", "roles"],
  "properties": {
    "messageType": { "const": "EndAssessmentMessage", "$comment": "specRef: §5 (message_type)" },
    "version": { "const": "1.3.0", "$comment": "specRef: §5 (version)" },
    "deploymentId": { "type": "string", "$comment": "specRef: §5 (deployment_id)" },
    "targetLinkUri": { "type": "string", "$comment": "specRef: §5 (target_link_uri)" },
    "subject": { "type": "string", "$comment": "specRef: §5 (sub)" },
    "attemptNumber": { "type": "integer", "$comment": "specRef: §5 (attempt_number)" },
    "roles": { "type": "array", "items": { "type": "string" }, "$comment": "specRef: §5 (roles)" },
    "context": { "$ref": "#/$defs/EaContext", "$comment": "specRef: §5 (context)" },
    "launchPresentation": { "$ref": "#/$defs/EaLaunchPresentation", "$comment": "specRef: §5 (launch_presentation)" },
    "lis": { "$ref": "#/$defs/EaLis", "$comment": "specRef: §5 (lis)" },
    "custom": { "type": "object", "$comment": "specRef: §5 (custom)" },
    "assessmentProctoringSettings": {
      "$ref": "#/$defs/EaProctoringSettings",
      "$comment": "specRef: §5 (proctoring_settings)"
    },
    "errorMessage": { "type": "string", "$comment": "specRef: §5 (errormsg)" },
    "errorLog": { "type": "string", "$comment": "specRef: §5 (errorlog)" }
  },
  "$defs": {
    "EaContext": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "$comment": "specRef: §5 (context.id)" },
        "label": { "type": "string", "$comment": "specRef: §5 (context.label)" },
        "title": { "type": "string", "$comment": "specRef: §5 (context.title)" },
        "type": { "type": "array", "items": { "type": "string" }, "$comment": "specRef: §5 (context.type)" }
      }
    },
    "EaLaunchPresentation": {
      "type": "object",
      "properties": {
        "documentTarget": {
          "type": "string",
          "enum": ["embed", "frame", "iframe", "popup", "tab", "window"],
          "$comment": "specRef: §5 (launch_presentation.document_target)"
        },
        "locale": { "type": "string", "$comment": "specRef: §5 (launch_presentation.locale)" },
        "height": { "type": "integer", "$comment": "specRef: §5 (launch_presentation.height)" },
        "width": { "type": "integer", "$comment": "specRef: §5 (launch_presentation.width)" },
        "returnUrl": { "type": "string", "$comment": "specRef: §5 (launch_presentation.return_url)" }
      }
    },
    "EaLis": {
      "type": "object",
      "properties": {
        "personSourcedId": { "type": "string", "$comment": "specRef: §5 (lis.person_sourcedid)" },
        "courseOfferingSourcedId": { "type": "string", "$comment": "specRef: §5 (lis.course_offering_sourcedid)" },
        "courseSectionSourcedId": { "type": "string", "$comment": "specRef: §5 (lis.course_section_sourcedid)" },
        "membershipSourcedId": { "type": "string", "$comment": "specRef: §5 (lis.membership_sourcedid)" }
      }
    },
    "EaProctoringSettings": {
      "type": "object",
      "title": "assessment proctoring settings",
      "properties": {
        "proctoringUrl": { "type": "string", "$comment": "specRef: §5 (proctoring_settings.proctoring_url)" },
        "startAssessmentUrl": { "type": "string", "$comment": "specRef: §5 (proctoring_settings.start_assessment_url)" },
        "endAssessmentReturnUrl": {
          "type": "string",
          "$comment": "specRef: §5 (proctoring_settings.end_assessment_return_url)"
        },
        "assessmentControlUrl": {
          "type": "string",
          "$comment": "specRef: §5 (proctoring_settings.assessment_control_url)"
        },
        "sessionData": { "type": "string", "$comment": "specRef: §5 (proctoring_settings.session_data)" },
        "extraTime": { "type": "integer", "$comment": "specRef: §5 (proctoring_settings.extra_time)" }
      }
    }
  }
}
