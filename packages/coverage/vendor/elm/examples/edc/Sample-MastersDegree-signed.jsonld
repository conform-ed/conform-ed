:\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}}}},\"logo\":{\"id\":\"urn:epass:mediaObject:1\",\"type\":\"MediaObject\",\"content\":\"\",\"contentEncoding\":{\"id\":\"http://data.europa.eu/snb/encoding/6146cde7dd\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/encoding/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"base64\"}},\"contentType\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type/PNG\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type\",\"type\":\"ConceptScheme\"},\"notation\":\"file-type\",\"prefLabel\":{\"en\":\"PNG\"}}},\"vatIdentifier\":{\"id\":\"urn:epass:legalIdentifier:2\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"altLabel\":{\"en\":\"UMU\"},\"legalName\":{\"en\":\"Umea university\"},\"registration\":{\"id\":\"urn:epass:legalIdentifier:2\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"homepage\":{\"id\":\"urn:epass:webResource:1\",\"type\":\"WebResource\",\"contentURL\":\"http://www.umu.se/english/?languageId=1\"}}},\"influencedBy\":{\"id\":\"urn:epass:activity:3\",\"type\":\"LearningActivity\",\"additionalNote\":{\"id\":\"urn:epass:note:8\",\"type\":\"Note\",\"noteLiteral\":{\"en\":\"Jenkins, H., Ford, S. & Green, J. (2013). Spreadable media. Creating value and meaning in networked culture. New York & London: New York University Press. Jordan, T. (2015). Information politics: liberation and exploitation in the digital society. Digital Barricades. London: Pluto.\"},\"subject\":{\"id\":\"urn:epass:concept:d2ea335a-30ea-40b5-922e-d91846c3210e\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"urn:epass:conceptScheme:563d8d91-edb7-46c9-b49c-d9860c9e5689\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Recommended reading\"}}},\"awardedBy\":{\"id\":\"urn:epass:awardingProcess:1\",\"type\":\"AwardingProcess\",\"awardingBody\":{\"id\":\"urn:epass:org:1\",\"type\":\"Organisation\",\"location\":{\"id\":\"urn:epass:location:1\",\"type\":\"Location\",\"address\":{\"id\":\"urn:epass:address:1\",\"type\":\"Address\",\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}}}},\"logo\":{\"id\":\"urn:epass:mediaObject:1\",\"type\":\"MediaObject\",\"content\":\"\",\"contentEncoding\":{\"id\":\"http://data.europa.eu/snb/encoding/6146cde7dd\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/encoding/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"base64\"}},\"contentType\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type/PNG\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type\",\"type\":\"ConceptScheme\"},\"notation\":\"file-type\",\"prefLabel\":{\"en\":\"PNG\"}}},\"vatIdentifier\":{\"id\":\"urn:epass:legalIdentifier:2\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"altLabel\":{\"en\":\"UMU\"},\"legalName\":{\"en\":\"Umea university\"},\"registration\":{\"id\":\"urn:epass:legalIdentifier:2\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"homepage\":{\"id\":\"urn:epass:webResource:1\",\"type\":\"WebResource\",\"contentURL\":\"http://www.umu.se/english/?languageId=1\"}}},\"specifiedBy\":{\"id\":\"urn:epass:learningActivitySpec:3\",\"type\":\"LearningActivitySpecification\",\"mode\":{\"id\":\"http://data.europa.eu/snb/learning-assessment/9191af2ed9\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-assessment/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Presential\"}},\"language\":{\"id\":\"http://publications.europa.eu/resource/authority/language/ENG\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/language\",\"type\":\"ConceptScheme\"},\"notation\":\"language\",\"prefLabel\":{\"en\":\"English\"}},\"title\":{\"en\":\"Real Virtualities. The relation between real and virtual dimensions of contemporary media culture\"}},\"description\":{\"en\":\"Media extend our senses and our engagement with the world - as Marshall McLuhan, the father of media studies, famously said. In this process they do not leave things untouched, but transform how we experience our environment and how we act in it. Through news media we are an immediate witness to events all over the globe. With web cameras we access the world online from wherever we are. Our cell phones help us to keep our friends with us anywhere we go. In these processes, off and online existence, becomes inextricably entangled. This module reflects on the emerging culture\\nof \u2018real virtuality\u2019. Students are introduced to two main philosophers that have dealt with the changing relationship between \u2018the real\u2019 and \u2018the virtual\u2019 (W. Benjamin, J. Baudrillard). The issues they address in relationship to older media such as photography, film and television is related to new media practices, such as telepresence and augmented reality, and evaluated in the light of these. The methodology employed is phenomenology. Where the thinkers mentioned above take an overarching approach, D. Ihde\u2019s phenomenology focuses on concrete sets of perceptual relations between users, media and the world and helps to make more nuanced analyses. During the module students discuss different media applications, including media artworks, and work towards their own analysis of an application in the light of the themes discussed.\"},\"temporal\":{\"id\":\"urn:epass:period:1\",\"type\":\"PeriodOfTime\",\"endDate\":\"2017-10-27T00:00:00+02:00\",\"startDate\":\"2017-09-04T00:00:00+02:00\"},\"title\":{\"en\":\"Real Virtualities. The relation between real and virtual dimensions of contemporary media culture\"}},\"provenBy\":{\"id\":\"urn:epass:learningAssessment:3\",\"type\":\"LearningAssessment\",\"awardedBy\":{\"id\":\"urn:epass:awardingProcess:1\",\"type\":\"AwardingProcess\",\"awardingBody\":{\"id\":\"urn:epass:org:1\",\"type\":\"Organisation\",\"location\":{\"id\":\"urn:epass:location:1\",\"type\":\"Location\",\"address\":{\"id\":\"urn:epass:address:1\",\"type\":\"Address\",\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}}}},\"logo\":{\"id\":\"urn:epass:mediaObject:1\",\"type\":\"MediaObject\",\"content\":\"\",\"contentEncoding\":{\"id\":\"http://data.europa.eu/snb/encoding/6146cde7dd\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/encoding/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"base64\"}},\"contentType\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type/PNG\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type\",\"type\":\"ConceptScheme\"},\"notation\":\"file-type\",\"prefLabel\":{\"en\":\"PNG\"}}},\"vatIdentifier\":{\"id\":\"urn:epass:legalIdentifier:2\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"altLabel\":{\"en\":\"UMU\"},\"legalName\":{\"en\":\"Umea university\"},\"registration\":{\"id\":\"urn:epass:legalIdentifier:2\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"homepage\":{\"id\":\"urn:epass:webResource:1\",\"type\":\"WebResource\",\"contentURL\":\"http://www.umu.se/english/?languageId=1\"}}},\"grade\":{\"id\":\"urn:epass:note:7\",\"type\":\"Note\",\"noteLiteral\":{\"en\":\"8,0\"}},\"idVerification\":{\"id\":\"http://data.europa.eu/snb/supervision-verification/70be69aaf9\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/supervision-verification/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Supervised with ID Verification\"}},\"specifiedBy\":{\"id\":\"urn:epass:learningAssessmentSpec:1\",\"type\":\"LearningAssessmentSpecification\",\"gradingScheme\":{\"id\":\"urn:epass:gradingScheme:1\",\"type\":\"GradingScheme\",\"description\":{\"en\":\"Grades are awarded on a scale from 1 to 10. Grades from 1 to 5.4 (Bachelor) / 5.9 (Master\u2019s) indicate a FAIL. Grades from 5.5 (Bachelor) / 6.0 (Master\u2019s) to 10 indicate a PASS.\\n1. Very bad\\n2. Bad\\n3. Low\\n4. Insufficient\\n5. Almost sufficient \\n6. Sufficient\\n7. Ample sufficient \\n8. Good \\n9. Very good \\n10. Excellent\"},\"title\":{\"en\":\"National grading\"}},\"language\":{\"id\":\"http://publications.europa.eu/resource/authority/language/ENG\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/language\",\"type\":\"ConceptScheme\"},\"notation\":\"language\",\"prefLabel\":{\"en\":\"English\"}},\"title\":{\"en\":\"Overall Assessment\"},\"dcType\":{\"id\":\"http://data.europa.eu/snb/assessment/3484bd7e51\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/assessment/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"continuous evaluation\"}}},\"description\":{\"en\":\"The overall grade is influenced by, and composed of, written assignments and a final paper.\"},\"title\":{\"en\":\"Overall Assessment\"}},\"specifiedBy\":{\"id\":\"urn:epass:learningAchievementSpec:3\",\"type\":\"LearningAchievementSpecification\",\"thematicArea\":[{\"id\":\"http://data.europa.eu/snb/isced-f/0211\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/isced-f/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Audio-visual techniques and media production\"}},{\"id\":\"http://data.europa.eu/snb/isced-f/021\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/isced-f/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Arts\"}},{\"id\":\"http://data.europa.eu/snb/isced-f/02\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/isced-f/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Arts and humanities\"}}],\"creditPoint\":{\"id\":\"urn:epass:creditPoint:1\",\"type\":\"CreditPoint\",\"framework\":{