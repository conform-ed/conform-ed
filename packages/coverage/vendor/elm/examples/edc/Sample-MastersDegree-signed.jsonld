tions.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"altLabel\":{\"en\":\"UMU\"},\"legalName\":{\"en\":\"Umea university\"},\"registration\":{\"id\":\"urn:epass:legalIdentifier:2\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"homepage\":{\"id\":\"urn:epass:webResource:1\",\"type\":\"WebResource\",\"contentURL\":\"http://www.umu.se/english/?languageId=1\"}}},\"influencedBy\":{\"id\":\"urn:epass:activity:9\",\"type\":\"LearningActivity\",\"awardedBy\":{\"id\":\"urn:epass:awardingProcess:1\",\"type\":\"AwardingProcess\",\"awardingBody\":{\"id\":\"urn:epass:org:1\",\"type\":\"Organisation\",\"location\":{\"id\":\"urn:epass:location:1\",\"type\":\"Location\",\"address\":{\"id\":\"urn:epass:address:1\",\"type\":\"Address\",\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}}}},\"logo\":{\"id\":\"urn:epass:mediaObject:1\",\"type\":\"MediaObject\",\"content\":\"\",\"contentEncoding\":{\"id\":\"http://data.europa.eu/snb/encoding/6146cde7dd\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/encoding/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"base64\"}},\"contentType\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type/PNG\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type\",\"type\":\"ConceptScheme\"},\"notation\":\"file-type\",\"prefLabel\":{\"en\":\"PNG\"}}},\"vatIdentifier\":{\"id\":\"urn:epass:legalIdentifier:2\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"altLabel\":{\"en\":\"UMU\"},\"legalName\":{\"en\":\"Umea university\"},\"registration\":{\"id\":\"urn:epass:legalIdentifier:2\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"homepage\":{\"id\":\"urn:epass:webResource:1\",\"type\":\"WebResource\",\"contentURL\":\"http://www.umu.se/english/?languageId=1\"}}},\"specifiedBy\":{\"id\":\"urn:epass:learningActivitySpec:9\",\"type\":\"LearningActivitySpecification\",\"mode\":{\"id\":\"http://data.europa.eu/snb/learning-assessment/9191af2ed9\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-assessment/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Presential\"}},\"language\":{\"id\":\"http://publications.europa.eu/resource/authority/language/ENG\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/language\",\"type\":\"ConceptScheme\"},\"notation\":\"language\",\"prefLabel\":{\"en\":\"English\"}},\"title\":{\"en\":\"Sound Technologies and Cultural Practices\"}},\"description\":{\"en\":\"This course aims to provide the learner with a better understanding of the changing relationships between sound technologies and cultural practices, notably music-related practices. Course participants analyse these relationships with the help of theories and concepts from media studies and science & technology studies (S&TS). These help the characteristics of cultural practices through historical examples and by familiarising, with a key method for understanding everyday culture: ethnographic research. This method enables the learners to unravel the taken-for-granted meanings and activities predominating in particular cultural practices. Such practices may vary from listening to music at home, the car or the concert hall, making and composing music with new sampling technologies or electronic musical instruments, downloading and sharing music online or amplifying music at festivals. Finally, this course teaches transformation of the learners' knowledge and research of sound technologies and cultural practices into a short podcast. As consumers increasingly listen to short radio-like features such as podcasts, audio books and audio guides, knowledge of basic sound production techniques provide a much-valued professional skill.\"},\"temporal\":{\"id\":\"urn:epass:period:3\",\"type\":\"PeriodOfTime\",\"endDate\":\"2017-12-22T00:00:00+01:00\",\"startDate\":\"2017-10-30T00:00:00+01:00\"},\"title\":{\"en\":\"Sound Technologies and Cultural Practices\"}},\"provenBy\":{\"id\":\"urn:epass:learningAssessment:9\",\"type\":\"LearningAssessment\",\"awardedBy\":{\"id\":\"urn:epass:awardingProcess:1\",\"type\":\"AwardingProcess\",\"awardingBody\":{\"id\":\"urn:epass:org:1\",\"type\":\"Organisation\",\"location\":{\"id\":\"urn:epass:location:1\",\"type\":\"Location\",\"address\":{\"id\":\"urn:epass:address:1\",\"type\":\"Address\",\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}}}},\"logo\":{\"id\":\"urn:epass:mediaObject:1\",\"type\":\"MediaObject\",\"content\":\"\",\"contentEncoding\":{\"id\":\"http://data.europa.eu/snb/encoding/6146cde7dd\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/encoding/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"base64\"}},\"contentType\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type/PNG\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type\",\"type\":\"ConceptScheme\"},\"notation\":\"file-type\",\"prefLabel\":{\"en\":\"PNG\"}}},\"vatIdentifier\":{\"id\":\"urn:epass:legalIdentifier:2\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"altLabel\":{\"en\":\"UMU\"},\"legalName\":{\"en\":\"Umea university\"},\"registration\":{\"id\":\"urn:epass:legalIdentifier:2\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"homepage\":{\"id\":\"urn:epass:webResource:1\",\"type\":\"WebResource\",\"contentURL\":\"http://www.umu.se/english/?languageId=1\"}}},\"grade\":{\"id\":\"urn:epass:note:10\",\"type\":\"Note\",\"noteLiteral\":{\"en\":\"7,5\"}},\"idVerification\":{\"id\":\"http://data.europa.eu/snb/supervision-verification/70be69aaf9\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/supervision-verification/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Supervised with ID Verification\"}},\"specifiedBy\":{\"id\":\"urn:epass:learningAssessmentSpec:1\",\"type\":\"LearningAssessmentSpecification\",\"gradingScheme\":{\"id\":\"urn:epass:gra