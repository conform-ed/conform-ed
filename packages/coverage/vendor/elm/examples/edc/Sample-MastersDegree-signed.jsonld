concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"study media sources\"}},{\"id\":\"http://data.europa.eu/esco/skill/db33c0f3-43ee-4ba3-ba47-9269ac837697\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/esco/concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"critically evaluate information and its sources \"}},{\"id\":\"http://data.europa.eu/esco/skill/253112b8-f613-4e1d-a691-d80ca258e21a\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/esco/concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"media studies\"}},{\"id\":\"http://data.europa.eu/esco/skill/574257ea-7b64-4100-b7b6-e27c233fe143\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/esco/concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"digital communication and collaboration\"}},{\"id\":\"http://data.europa.eu/esco/skill/89c1d71c-f443-4e60-a7c3-f824ecb10597\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/esco/concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"types of media\"}},{\"id\":\"http://data.europa.eu/esco/skill/67dbfc2a-3dd4-41a1-90bd-97035e7add60\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/esco/concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"stay up to date with social media\"}},{\"id\":\"http://data.europa.eu/esco/skill/fef96bad-e623-42cd-b961-d1adf39db8b9\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/esco/concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"media and information literacy \"}}],\"title\":{\"en\":\"Media in Public Spheres\"}},\"learningOutcomeSummary\":{\"id\":\"urn:epass:note:11\",\"type\":\"Note\",\"noteLiteral\":{\"en\":\"The qua