epass:location:1\",\"type\":\"Location\",\"address\":{\"id\":\"urn:epass:address:1\",\"type\":\"Address\",\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}}}},\"logo\":{\"id\":\"urn:epass:mediaObject:1\",\"type\":\"MediaObject\",\"content\":\"\",\"contentEncoding\":{\"id\":\"http://data.europa.eu/snb/encoding/6146cde7dd\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/encoding/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"base64\"}},\"contentType\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type/PNG\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type\",\"type\":\"ConceptScheme\"},\"notation\":\"file-type\",\"prefLabel\":{\"en\":\"PNG\"}}},\"vatIdentifier\":{\"id\":\"urn:epass:legalIdentifier:2\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"altLabel\":{\"en\":\"UMU\"},\"legalName\":{\"en\":\"Umea university\"},\"registration\":{\"id\":\"urn:epass:legalIdentifier:2\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"homepage\":{\"id\":\"urn:epass:webResource:1\",\"type\":\"WebResource\",\"contentURL\":\"http://www.umu.se/english/?languageId=1\"}}},\"influencedBy\":{\"id\":\"urn:epass:activity:1\",\"type\":\"LearningActivity\",\"additionalNote\":{\"id\":\"urn:epass:note:2\",\"type\":\"Note\",\"noteLiteral\":{\"en\":\"Jenkins, H., Ford, S. & Green, J. (2013). Spreadable media. Creating value and meaning in networked culture. New York & London: New York University Press. Jordan, T. (2015). Information politics: liberation and exploitation in the digital society. Digital Barricades. London: Pluto.\"},\"subject\":{\"id\":\"urn:epass:concept:152617af-8de2-46e2-97a8-ce2781c39402\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"urn:epass:conceptScheme:a0c597de-0e68-4aa6-94d9-b40d65f81023\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Recommended reading\"}}},\"awardedBy\":{\"id\":\"urn:epass:awardingProcess:1\",\"type\":\"AwardingProcess\",\"awardingBody\":{\"id\":\"urn:epass:org:1\",\"type\":\"Organisation\",\"location\":{\"id\":\"urn:epass:location:1\",\"type\":\"Location\",\"address\":{\"id\":\"urn:epass:address:1\",\"type\":\"Address\",\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}}}},\"logo\":{\"id\":\"urn:epass:mediaObject:1\",\"type\":\"MediaObject\",\"content\":\"\",\"contentEncoding\":{\"id\":\"http://data.europa.eu/snb/encoding/6146cde7dd\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/encoding/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"base64\"}},\"contentType\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type/PNG\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type\",\"type\":\"ConceptScheme\"},\"notation\":\"file-type\",\"prefLabel\":{\"en\":\"PNG\"}}},\"vatIdentifier\":{\"id\":\"urn:epass:legalIdentifier:2\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"altLabel\":{\"en\":\"UMU\"},\"legalName\":{\"en\":\"Umea university\"},\"registration\":{\"id\":\"urn:epass:legalIdentifier:2\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"homepage\":{\"id\":\"urn:epass:webResource:1\",\"type\":\"WebResource\",\"contentURL\":\"http://www.umu.se/english/?languageId=1\"}}},\"specifiedBy\":{\"id\":\"urn:epass:learningActivitySpec:1\",\"type\":\"LearningActivitySpecification\",\"mode\":{\"id\":\"http://data.europa.eu/snb/learning-assessment/9191af2ed9\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-assessment/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Presential\"}},\"language\":{\"id\":\"http://publications.europa.eu/resource/authority/language/ENG\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/language\",\"type\":\"ConceptScheme\"},\"notation\":\"language\",\"prefLabel\":{\"en\":\"English\"}},\"title\":{\"en\":\"Transformations in Digital Cultures\"}},\"description\":{\"en\":\"This module focuses on the impact of recent transformations of our media landscape on society and culture. We discuss how the architecture of the web controls but also enables user practices. We start with an analysis of the web, specifically search engines and social media. User and (online) communities use but also partly depend on digital technology, they make use of digital data, online networks and the specific characteristics of digital media. These often include digital natives who are growing up with an understanding that sharing (digital) data is essential of how friendships and communities are being built and maintained. The internet has facilitated and allowed for individual users and communities to create, configure and control content. At the same time users give information about the number of connections (friends), activities within the networks (status updates, likes, shares). Numbers, ranks and scores structure our online presence; they are used by us but also by observers with commercial or political interests. The method introduced in this module is discourse analysis. We investigate discourses about user practices, participation, net activism and hacking and analyse them.\"},\"temporal\":{\"id\":\"urn:epass:period:1\",\"type\":\"PeriodOfTime\",\"endDate\":\"2017-10-27T00:00:00+02:00\",\"startDate\":\"2017-09-04T00:00:00+02:00\"},\"title\":{\"en\":\"Transformations in Digital Cultures\"}},\"provenBy\":{\"id\":\"urn:epass:learningAssessment:1\",\"type\":\"LearningAssessment\",\"awardedBy\":{\"id\":\"urn:epass:awardingProcess:1\",\"type\":\"AwardingProcess\",\"awardingBody\":{\"id\":\"urn:epass:org:1\",\"type\":\"Organisation\",\"location\":{\"id\":\"urn:epass:location:1\",\"type\":\"Location\",\"address\":{\"id\":\"urn:epass:address:1\",\"type\":\"Address\",\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}}}},\"logo\":{\"id\":\"urn:epass:mediaObject:1\",\"type\":\"MediaObject\",\"content\":\"\",\"contentEncoding\":{\"id\":\"http://data.europa.eu/snb/encoding/6146cde7dd\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/encoding/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"base64\"}},\"contentType\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type/PNG\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/file-type\",\"type\":\"ConceptScheme\"},\"notation\":\"file-type\",\"prefLabel\":{\"en\":\"PNG\"}}},\"vatIdentifier\":{\"id\":\"urn:epass:legalIdentifier:2\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"altLabel\":{\"en\":\"UMU\"},\"legalName\":{\"en\":\"Umea university\"},\"registration\":{\"id\":\"urn:epass:legalIdentifier:2\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/SWE\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Sweden\"}},\"notation\":\"SE202100287401\"},\"homepage\":{\"id\":\"urn:epass:webResource:1\",\"type\":\"WebResource\",\"contentURL\":\"http://www.umu.se/english/?languageId=1\"}}},\"grade\":{\"id\":\"urn:epass:note:1\",\"type\":\"Note\",\"noteLiteral\":{\"en\":\"7,0\"}},\"idVerification\":{\"id\":\"http://data.europa.eu/snb/supervision-verification/70be69aaf9\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/supervision-verification/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Supervised with ID Verification\"}},\"specifiedBy\":{\"id\":\"urn:epass:learningAssessmentSpec:1\",\"type\":\"LearningAssessmentSpecification\",\"gradingScheme\":{\"id\":\"urn:epass:gradingScheme:1\",\"type\":\"GradingScheme\",\"description\":{\"en\":\"Grades are awarded on a scale from 1 to 10. Grades from 1 to 5.4 (Bachelor) / 5.9 (Master\u2019s) indicate a FAIL. Grades from 5.5 (Bachelor) / 6.0 (Master\u2019s) to 10 indicate a PASS.\\n1. Very bad\\n2. Bad\\n3. Low\\n4. Insufficient\\n5. Almost sufficient \\n6. Sufficient\\n7. Ample sufficient \\n8. Good \\n9. Very good \\n10. Excellent\"},\"title\":{\"en\":\"National grading\"}},\"language\":{\"id\":\"http://publications.europa.eu/resource/authority/language/ENG\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/language\",\"type\":\"ConceptScheme\"},\"notation\":\"language\",\"prefLabel\":{\"en\":\"English\"}},\"title\":{\"en\":\"Overall Assessment\"},\"dcType\":{\"id\":\"http://data.europa.eu/snb/assessment/3484bd7e51\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/assessment/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"continuous evaluation\"}}},\"description\":{\"en\":\"The overall grade is influenced by a final paper.\"},\"title\":{\"en\":\"Overall Assessment\"}},\"specifiedBy\":{\"id\":\"urn:epass:learningAchievementSpec:1\",\"type\":\"LearningAchievementSpecification\",\"thematicArea\":[{\"id\":\"http://data.europa.eu/snb/isced-f/02\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/isced-f/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Arts and humanities\"}},{\"id\":\"http://data.europa.eu/snb/isced-f/021\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/isced-f/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Arts\"}},{\"id\":\"http://data.europa.eu/snb/isced-f/0211\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/isced-f/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Audio-visual techniques and media production\"}}],\"creditPoint\":{\"id\":\"urn:epass:creditPoint:1\",\"type\":\"CreditPoint\",\"framework\":{\"id\":\"http://data.europa.eu/snb/education-credit/6fcec5c5af\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/education-credit/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"European Credit Transfer System\"}},\"point\":\"6.00\"},\"learningOutcome\":{\"id\":\"urn:epass:learningOutcome:1\",\"type\":\"LearningOutcome\",\"relatedESCOSkill\":[{\"id\":\"http://data.europa.eu/esco/skill/574257ea-7b64-4100-b7b6-e27c233fe143\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/esco/concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"digital communication and collaboration\"}},{\"id\":\"http://data.europa.eu/esco/skill/696e604d-53d2-4243-a6cb-a99663caa119\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/esco/concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"monitor social impact\"}},{\"id\":\"http://data.europa.eu/esco/skill/253112b8-f613-4e1d-a691-d80ca258e21a\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/esco/concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"media studies\"}},{\"id\":\"http://data.europa.eu/esco/skill/c8ab7e5b-b786-412f-a519-dfd93517b698\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/esco/concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"study media sources\"}},{\"id\":\"http://data.europa.eu/esco/skill/c2aacac0-5a16-4493-b769-e7c052916d39\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/esco/concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"anthropology\"}},{\"id\":\"http://data.europa.eu/esco/skill/89c1d71c-f443-4e60-a7c3-f824ecb10597\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/esco/concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"types of media\"}},{\"id\":\"http://data.europa.eu/esco/skill/5fd5c985-eaaa-47aa-8314-62359c54505a\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/esco/concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"develop digital content\"}},{\"id\":\"http://data.europa.eu/esco/skill/f5019d58-1f9a-4c1d-9a68-6ed7b8ec3eca\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/esco/concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"study human societies\"}},{\"id\":\"http://data.europa.eu/esco/skill/4707da90-9cfc-46ca-8de0-38a0b7bfb137\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/esco/concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"think analytically\"}},{\"id\":\"http://data.europa.eu/esco/skill/03bc5f23-4317-41c2-9528-2db5c3c87b85\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/esco/concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"analyse cultural trends\"}}],\"title\":{\"en\":\"Transformations in Digital Cultures\"}},\"learningOutcomeSummary\":{\"id\":\"urn:epass:note:3\",\"type\":\"Note\",\"noteLiteral\":{\"en\":\"The qualification holder is able to:\\n(1) function confidently in digital cultures; \\n(2) understand the history and theory of new media; \\n(3) recognise social media and user practices as e.g. net activism and hacking; \\n(4) apply problem based learning; \\n(5) analyse discourse; \\n(6) write for a research weblog and apply basic programming skills.\"}},\"learningSetting\":{\"id\":\"http://data.europa.eu/snb/learning-setting/6fd4685715\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-setting/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"formal learning\"}},\"mode\":{\"id\":\"http://data.europa.eu/snb/learning-assessment/9191af2ed9\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-assessment/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Presential\"}}