f media\"}},{\"id\":\"http://data.europa.eu/esco/skill/4707da90-9cfc-46ca-8de0-38a0b7bfb137\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/esco/concept-scheme/skills\",\"type\":\"ConceptScheme\"},\"notation\":\"Skill\",\"prefLabel\":{\"en\":\"think analytically\"}}],\"title\":{\"en\":\"Contemporary media culture study\"}},\"learningOutcomeSummary\":{\"id\":\"urn:epass:note:17\",\"type\":\"Note\",\"noteLiteral\":{\"en\":\"The qualification holder is able to:\\n(1) understand three relevant philosophical positions; \\n(2) apply phenomenological analysis of media.\"}},\"learningSetting\":{\"id\":\"http://data.europa.eu/snb/learning-setting/6fd4685715\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-setting/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"formal learning\"}},\"mode\":{\"id\":\"http://data.europa.eu/snb/learning-assessment/9191af2ed9\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-assessment/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Presential\"}},\"language\":{\"id\":\"http://publications.europa.eu/resource/authority/language/ENG\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/language\",\"type\":\"ConceptScheme\"},\"notation\":\"language\",\"prefLabel\":{\"en\":\"English\"}},\"title\":{\"en\":\"Real Virtualities. The relation between real and virtual dimensions of contemporary media culture\"},\"dcType\":{\"id\":\"http://data.europa.eu/snb/learning-opportunity/0f7dac46ca\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-opportunity/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Programme module\"}}},\"title\":{\"en\":\"Real Virtualities. The relation between real and virtual dimensions of contemporary media culture\"}},{\"id\":\"urn:epass:learningAchievement:9\",\"type\":\"LearningAchievement\",\"awardedBy\":{\"id\":\"urn:epass:awardingProcess: