rn:epass:legalIdentifier:4\",\"type\":\"LegalIdentifier\",\"spatial\":{\"id\":\"http://publications.europa.eu/resource/authority/country/IRL\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Ireland\"}},\"notation\":\"0000\"},\"homepage\":{\"id\":\"urn:epass:webResource:3\",\"type\":\"WebResource\",\"contentURL\":\"https://learningprovider.edu\"}}},\"specifiedBy\":{\"id\":\"urn:epass:learningActivitySpec:6\",\"type\":\"LearningActivitySpecification\",\"mode\":{\"id\":\"http://data.europa.eu/snb/learning-assessment/9191af2ed9\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://data.europa.eu/snb/learning-assessment/25831c2\",\"type\":\"ConceptScheme\"},\"prefLabel\":{\"en\":\"Presential\"}},\"language\":{\"id\":\"http://publications.europa.eu/resource/authority/language/ENG\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/language\",\"type\":\"ConceptScheme\"},\"notation\":\"language\",\"prefLabel\":{\"en\":\"English\"}},\"title\":{\"en\":\"Research Design\"}},\"description\":{\"en\":\"In this module students draw together what they have learned before and apply their theoretical insights, research methods, and practical skills in order to design their research plan for the second semester thesis. Each of the five first-semester modules emphasised a particular disciplinary and/or theoretical approach and a specific methodology, but always in a problem oriented and interdisciplinary context. In the second semester students develop their own research on developments and issues in contemporary media culture; the research plan supports them in connecting their own research questions and strategies to the previous modules. Students design this research plan in a step-by-step process. These steps are prepared by an introductory lecture. In the first week students explore their thesis topic and discuss their ideas. Students also take part in a workshop on how to peer-review a research proposal. In the subsequent weeks, students support each other by engaging in weekly peer-review sessions in which they critically evaluate the work of their colleagues.\"},\"temporal\":{\"id\":\"urn:epass:period:4\",\"type\":\"PeriodOfTime\",\"endDate\":\"2018-03-09T00:00:00+01:00\",\"startDate\":\"2018-02-05T00:00:00+01:00\"},\"title\":{\"en\":\"Research Design\"}},\"provenBy\":{\"id\":\"urn:epass:learningAssessment:6\",\"type\":\"LearningAssessment\",\"awardedBy\":{\"id\":\"urn:epass:awardingProcess:1\",\"type\":\"AwardingProcess\",\"awardingBody\":{\"id\":\"urn:epass:org:2\",\"type\":\"Organisation\",\"accreditation\":{\"id\":\"urn:epass:accreditation:1\",\"type\":\"Accreditation\",\"accreditingAgent\":{\"id\":\"urn:epass:org:1\",\"type\":\"Organisation\",\"contactPoint\":{\"id\":\"urn:epass:contactPoint:1\",\"type\":\"ContactPoint\",\"address\":{\"id\":\"urn:epass:address:2\",\"type\":\"Address\",\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/IRL\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Ireland\"}},\"fullAddress\":{\"id\":\"urn:epass:note:1\",\"type\":\"Note\",\"noteLiteral\":{\"en\":\"Octagon square 4, D08 Dublin\"}}},\"emailAddress\":{\"id\":\"mailto:secretariat@naqa.ie\",\"type\":\"Mailbox\"},\"phone\":{\"id\":\"urn:epass:phone:1\",\"type\":\"Phone\",\"phoneNumber\":\"+353123456789\"}},\"location\":{\"id\":\"urn:epass:location:1\",\"type\":\"Location\",\"address\":{\"id\":\"urn:epass:address:1\",\"type\":\"Address\",\"countryCode\":{\"id\":\"http://publications.europa.eu/resource/authority/country/IRL\",\"type\":\"Concept\",\"inScheme\":{\"id\":\"http://publications.europa.eu/resource/authority/country\",\"type\":\"ConceptScheme\"},\"notation\":\"country\",\"prefLabel\":{\"en\":\"Ireland\"}}}},\"l