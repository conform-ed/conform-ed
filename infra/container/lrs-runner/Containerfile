FROM docker.io/oven/bun:1.3.14 AS builder
WORKDIR /app

COPY package.json bun.lock ./
COPY packages/contracts ./packages/contracts
COPY apps/lrs-runner ./apps/lrs-runner

RUN bun install --cwd apps/lrs-runner
RUN bun build apps/lrs-runner/src/cli.ts --outdir dist --target bun

FROM docker.io/oven/bun:1.3.14
WORKDIR /app

COPY --from=builder /app/dist ./dist
COPY apps/lrs-runner/runtime ./runtime
COPY scripts/run-lrs-runner-dual.sh ./scripts/run-lrs-runner-dual.sh

RUN printf '{"name":"r","type":"module","dependencies":{"jose":"^6.0.0"}}' > package.json \
    && bun install --production

ENTRYPOINT ["bash", "./scripts/run-lrs-runner-dual.sh"]
