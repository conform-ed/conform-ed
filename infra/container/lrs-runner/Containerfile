FROM docker.io/oven/bun:1.3.14
WORKDIR /app

COPY package.json bun.lock ./
COPY packages/contracts ./packages/contracts
COPY apps/lrs-runner ./apps/lrs-runner
COPY scripts/run-lrs-runner-dual.sh ./scripts/run-lrs-runner-dual.sh

RUN bun install --cwd apps/lrs-runner

ENTRYPOINT ["bash", "./scripts/run-lrs-runner-dual.sh"]
