FROM docker.io/oven/bun:1.3.14 AS builder
WORKDIR /app

COPY package.json bun.lock ./
COPY packages/contracts ./packages/contracts
COPY packages/qti-xml ./packages/qti-xml
COPY packages/cli ./packages/cli
COPY packages/core ./packages/core
COPY packages/reporting ./packages/reporting
COPY apps/cmi5-runner ./apps/cmi5-runner

RUN bun install --cwd apps/cmi5-runner
RUN bun build apps/cmi5-runner/src/index.ts --outdir dist --target bun

FROM docker.io/oven/bun:1.3.14
WORKDIR /app

COPY --from=builder /app/dist ./dist
COPY scripts/cmi5-lane-common.ts ./scripts/cmi5-lane-common.ts
COPY scripts/run-cmi5-external-lane.ts ./scripts/run-cmi5-external-lane.ts
COPY scripts/run-cmi5-catapult-style-lane.ts ./scripts/run-cmi5-catapult-style-lane.ts

CMD ["bun", "dist/index.js"]
